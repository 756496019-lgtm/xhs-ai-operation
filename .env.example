# 环境变量配置示例
# 拷贝此文件为 .env 并填入真实 key（.env 已被 .gitignore 排除）
# 或者在系统环境变量里设置

# ============================================
# 通义千问（DashScope）API Key — 必填
# ============================================
# 获取：https://dashscope.console.aliyun.com/
# 全仓 AI 调用统一读这一个变量
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Reddit 抓取（content-monitor 评论 scraper 用）
# ============================================
# 获取：https://www.reddit.com/prefs/apps  → 创建 script 类型 app
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=xhs-ai-operation/1.0 (by /u/your_username)

# ============================================
# 微博超话（可选，content-monitor 微博 scraper 用）
# ============================================
# 在浏览器登录微博后从 dev tools 复制完整 Cookie
# WEIBO_COOKIE=SUB=xxxx; SUBP=xxxx

# ============================================
# 定时任务（可选）
# ============================================
ENABLE_SCHEDULER=false
VIDEO_DAILY_COUNT=1
VIDEO_DEFAULT_GAME=原神
